# ─────────────────────────────────────────────────
# AIF369 Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git
# ─────────────────────────────────────────────────

# GCP Project
PROJECT_ID=aif369-backend
DATASET_ID=aif369_analytics
ENVIRONMENT=dev

# Gemini AI (get from GCP Secret Manager or Google AI Studio)
GEMINI_API_KEY=

# SMTP (Zoho Mail)
SMTP_USER=edaza@aif369.com
SMTP_PASSWORD=
NOTIFICATION_EMAIL=edaza@aif369.com
CC_EMAIL=erwin.daza@gmail.com

# Content Generation API Key
CONTENT_API_KEY=

# Ollama fallback (optional, for local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
